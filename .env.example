# Copy this file to .env.local (never commit .env.local)
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Base URL of any OpenAI-compatible chat-completions endpoint
VITE_LLM_BASE_URL=https://api.groq.com/openai/v1

# Your API key for that provider
VITE_LLM_API_KEY=

# Model name as the provider expects it
VITE_LLM_MODEL=llama-3.3-70b-versatile

# ── Debate parameters (optional overrides) ────────────────────────────────────
VITE_MAX_TOKENS=420
VITE_TURN_DELAY_MS=800
VITE_MAX_TURNS=14
