# YuktiAI Backend — copy to .env (never commit .env)

# ── Upstream LLM provider ─────────────────────────────────────────────────────
# Base URL of any OpenAI-compatible provider (no trailing slash)
LLM_BASE_URL=https://api.groq.com/openai

# API key for the upstream provider (kept server-side, never sent to browsers)
LLM_API_KEY=

# Default model — frontend model field takes precedence when set
LLM_MODEL=llama-3.3-70b-versatile

# ── Server ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins. Use "*" to allow all (default).
# Restrict to your GitHub Pages URL in production, e.g.:
#   ALLOWED_ORIGINS=https://yourname.github.io
ALLOWED_ORIGINS=*
